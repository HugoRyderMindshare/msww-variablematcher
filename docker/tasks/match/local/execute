#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DOCKER_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
CRED_FILE="${1:-$HOME/.config/gcloud/application_default_credentials.json}"

echo "Building Docker image..."
docker build --no-cache -f "$SCRIPT_DIR/build/Dockerfile" -t match "$DOCKER_DIR"

echo "Running container..."
docker run --rm \
    -v "$DOCKER_DIR/shared/data:/app/data" \
    -v "$SCRIPT_DIR/run/output:/app/output" \
    -v "$CRED_FILE:/app/credentials.json:ro" \
    -v "$SCRIPT_DIR/run/.env:/app/.env:ro" \
    -e GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json \
    match \
    python main.py
